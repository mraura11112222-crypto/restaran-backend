# ============================================
# RestoPro Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=RestoPro
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (PostgreSQL) ---
# For Neon: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/db?sslmode=require
# For Supabase: postgresql+asyncpg://postgres:pass@db.xxx.supabase.co:5432/postgres
# For Local: postgresql+asyncpg://postgres:pass@localhost:5432/restaurant_db
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/restaurant_db

# --- CORS ---
# Add your frontend URLs here
CORS_ORIGINS=["http://localhost:3002","http://localhost:3000","http://localhost:5173"]

# --- Cloudinary (Media Uploads) ---
# Get from https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- SMS Service (Eskiz.uz) ---
# Get from https://eskiz.uz
SMS_API_URL=https://notify.eskiz.uz/api
SMS_API_EMAIL=your@email.com
SMS_API_PASSWORD=your-sms-password

# --- Telegram Bot ---
# BotFather bergan tokenni shu yerga yozing
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Payment Gateways ---

# Click.uz
CLICK_MERCHANT_ID=your-merchant-id
CLICK_SERVICE_ID=your-service-id
CLICK_SECRET_KEY=your-click-secret

# Payme.uz
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret

# --- API Configuration ---
API_PREFIX=/api/v1

# --- Optional: Redis (for caching) ---
# REDIS_URL=redis://localhost:6379/0

# --- Optional: Email Service ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAILS_FROM_EMAIL=your-email@gmail.com
# EMAILS_FROM_NAME=RestoPro
